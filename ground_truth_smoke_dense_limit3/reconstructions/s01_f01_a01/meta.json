    "semi_major": "a = d_front / 2",
    "semi_minor": "d_right = right_width / 2, d_left = left_width / 2, b_right = sqrt(max(2*d_right^2 - a^2, 0)), b_left = sqrt(max(2*d_left^2 - a^2, 0)), b = 0.5 * (b_right + b_left)",
